<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Favorites</title>
    <%- include("partials/head.ejs") %>
</head>

<body>
    <%- include("partials/nav.ejs") %>
    <div class="container mt-5">
        <h1>My Favorites</h1>
        <% if (favorites.length > 0) { %>
            <div class="card">
                <div class="card-header">
                    <p class="text-muted"><%= favorites.length %> songs</p>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        <% favorites.forEach(song => { %>
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong><%= song.title %></strong> 
                                    <a href="/deleteFav?songTitle=<%= song.title %>" class="btn btn-danger btn-sm">X</a>
                                </div>
                                
                                <div class="text-muted">
                                    <a href="/artistInfo?artist=<%= encodeURIComponent(song.artistName) %>" style="color: inherit; text-decoration: none;">
                                        <%= song.artistName %>
                                    </a>
                                </div>
                                <% if (song.songURL) { %>
                                    <audio controls style="width: 100%; margin-top: 10px;">
                                        <source src="<%= song.songURL %>" type="audio/aac">
                                    </audio>
                                <% } %> 
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>
        <% } else { %>
            <p>No favorites found. <a href="/discover">Start discovering!</a></p>
        <% } %>
    </div>

    <br>

    <%- include("partials/footer") %>
</body>

</html>