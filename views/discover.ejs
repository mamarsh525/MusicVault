<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discover Music</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<%- include("partials/nav") %>

<div class="container text-center">
    <h1>Discover New Music</h1>
    <h2 ><%= artist %></h2>
    <% if (songs.length > 0) { %>
        <img src="<%= songs[0].artworkUrl100 %>"  class="img-fluid rounded mb-4">
        <h3>Top Songs</h3>
        <ul class="list-group">
            <% songs.forEach(song => { %>
                <li class="list-group-item">
                    <strong><%= song.trackName %></strong> - <%= song.collectionName %>
                </li>
            <% }) %>
        </ul>
    <% }%>
    <a href="/discover" class="btn btn-primary ">Next</a>
</div>
</body>
</html>