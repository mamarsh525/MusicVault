<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Discover Music</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include("partials/head") %>
</head>

<body>
    <%- include("partials/nav") %>

        <div class="container text-center">
            <h1>Discover New Music</h1>
            <h2>
                <%= artist %>
            </h2>
            <% if (songs.length> 0) { %>
                <div class="music-header">
                    <!-- Left: Artwork -->
                    <div class="music-artwork">
                        <a href="<%= songs[0].collectionViewUrl %>" target="_blank">
                            <img src="<%= songs[0].artworkUrl100 %>" class="album-img">
                        </a>
                    </div>
                    <!-- Middle: Top 3 Highlight (no dupes) -->
                    <div class="music-top3">
                        <h3>Top 3</h3>
                        <% songs.slice(0, 3).forEach((song, index)=> { %>
                            <div class="top3-item">
                                <div class="rank">#<%= index + 1 %>
                                </div>
                                <div class="info">
                                    <a href="<%= song.trackViewUrl %>" target="_blank" class="song-link">
                                        <strong>
                                            <%= song.trackName %>
                                        </strong>
                                    </a>
                                    <div class="text-muted">
                                        <%= song.collectionName %>
                                    </div>
                                    <form action="/addToPlaylist" method="POST" class="d-inline">
                                        <input type="hidden" name="song_id" value="<%= song.trackId %>">
                                        <input type="hidden" name="trackName" value="<%= song.trackName %>">
                                        <input type="hidden" name="artistName" value="<%= song.artistName %>">
                                        <input type="hidden" name="songURL" value="<%= song.previewUrl %>">
                                        <button type="submit" class="btn btn-success btn-sm">+</button>
                                    </form>

                                    <form action="/addToFavorites" method="POST" class="d-inline">
                                        <input type="hidden" name="trackName" value="<%= song.trackName %>">
                                        <input type="hidden" name="artistName" value="<%= song.artistName %>">
                                        <input type="hidden" name="songURL" value="<%= song.previewUrl %>">
                                        <button type="submit" class="btn btn-danger btn-sm">♥</button>
                                    </form>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <!-- Right: Full list -->
                    <div class="music-info">
                        <h3>Other Bangers</h3>
                        <ul class="list-group">
                            <% songs.slice(3).forEach(song=> { %>
                                <li class="list-group-item">
                                    <a href="<%= song.trackViewUrl %>" target="_blank" class="song-link">
                                        <strong>
                                            <%= song.trackName %>
                                        </strong>
                                    </a>
                                    <div class="text-muted">
                                        <%= song.collectionName %>
                                    </div>

                                    <form action="/addToPlaylist" method="POST" class="d-inline">
                                        <input type="hidden" name="song_id" value="<%= song.trackId %>">
                                        <input type="hidden" name="trackName" value="<%= song.trackName %>">
                                        <input type="hidden" name="artistName" value="<%= song.artistName %>">
                                        <input type="hidden" name="songURL" value="<%= song.previewUrl %>">
                                        <button type="submit" class="btn btn-success btn-sm">+</button>
                                    </form>

                                    <form action="/addToFavorites" method="POST" class="d-inline">
                                        <input type="hidden" name="trackName" value="<%= song.trackName %>">
                                        <input type="hidden" name="artistName" value="<%= song.artistName %>">
                                        <input type="hidden" name="songURL" value="<%= song.previewUrl %>">
                                        <button type="submit" class="btn btn-danger btn-sm">♥</button>
                                    </form>
                                </li>
                                <% }) %>
                        </ul>
                    </div>
                </div>
                <% }%>
                    <a href="/discover" class="btn btn-primary ">Next</a>
        </div>

        <br>

        <%- include("partials/footer") %>
</body>

</html>