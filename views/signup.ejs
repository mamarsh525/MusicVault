<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>Sign Up</h1>

    <% if (typeof signupError !=='undefined' ) { %>
        <p style="color:red;">
            <%= signupError %>
        </p>
    <% } %>

        <form action="/signupProcess" method="POST">

            <input type="text" name="firstName" placeholder="First Name" required>
            <br><br>

            <input type="text" name="lastName" placeholder="Last Name" required>
            <br><br>

            <input type="text" name="username" placeholder="Username" maxlength="16" required>
            <br><br>

            <input type="password" name="password" placeholder="Password" maxlength="72" required>
            <br><br>

            <button type="submit">Sign Up</button>

        </form>

        <a href="/login">Back to login</a>
</body>

</html>